# Flask
DIARY_SECRET_KEY=change-me-to-a-random-64-char-hex-string
FLASK_DEBUG=0

# Firebase Admin SDK (backend)
# Option A: paste the entire service account JSON as a single-line string
FIREBASE_ADMIN_CREDENTIALS_JSON={"type":"service_account",...}

# Option B: path to a local firebase-adminsdk.json file (dev only, never commit this file)
# FIREBASE_ADMIN_CREDENTIALS_JSON is checked first; file fallback used if absent

FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Firebase Web SDK (frontend)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI APIs
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant

HUGGINGFACE_API_KEY=
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# App Config
SITE_URL=https://worldbyyou.com
CONTACT_EMAIL=elementaldiary@gmail.com

# Cron Jobs
CRON_SECRET=change-me-to-a-random-secret

# DANGER: Dev only. NEVER set to 1 in production.
SHOW_AI_ERRORS=0
